# Supabase auth (sign up / sign in with email or phone)
# Create a free project at https://supabase.com — see SETUP-SUPABASE.txt
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SITE_URL=https://competencyflow.vercel.app

# Founder-only admin password (change this!)
ADMIN_PASSWORD=your-secure-admin-password

# AI Lesson Builder — get a key at https://platform.openai.com/api-keys
# Paste your key below (starts with sk-):
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional: change model (default gpt-4o-mini — fast & affordable)
# OPENAI_MODEL=gpt-4o-mini

# Transactional email (invite + login links) — free at https://resend.com
# Without this, invites still work but you'll copy links manually when Supabase rate-limits.
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=CompetencyFlow <onboarding@yourdomain.com>
