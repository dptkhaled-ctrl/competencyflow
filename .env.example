# Supabase auth (sign up / sign in with email or phone)
# Create a free project at https://supabase.com — see SETUP-SUPABASE.txt
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Founder-only admin password (change this!)
ADMIN_PASSWORD=your-secure-admin-password

# AI Lesson Builder — get a key at https://platform.openai.com/api-keys
# Paste your key below (starts with sk-):
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional: change model (default gpt-4o-mini — fast & affordable)
# OPENAI_MODEL=gpt-4o-mini
