# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# local deploy secrets (never commit)
.github-token
.vercel-token
.vercel-admin-password

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project specific - runtime data and uploads (not for version control)
private/
data/
*.log
.env*
